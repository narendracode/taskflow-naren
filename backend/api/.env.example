# Database (async driver for app, sync driver for alembic)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/taskflow
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/taskflow

# Redis — used for SSE pub/sub across multiple API nodes
REDIS_URL=redis://localhost:6379/0

# JWT — generate a strong random value for production
SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Logging
LOG_LEVEL=INFO

# CORS — comma-separated list of allowed origins, or * to allow all
CORS_ORIGINS=*
